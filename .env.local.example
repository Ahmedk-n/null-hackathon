# Copy to .env.local and fill in to run against the live Claude API.
# WITHOUT this key, every LLM wrapper falls back to deterministic fixtures,
# so the full offline demo still works. The key is read ONLY in server-side
# modules (src/app/api/**, src/llm/client.ts, src/llm/reinforce.ts,
# src/context/compile.ts) and must never reach the client bundle.
ANTHROPIC_API_KEY=sk-ant-...
